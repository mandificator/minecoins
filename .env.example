# CRM admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=generate-a-long-random-string

# Solana (placeholder până la mainnet)
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_PROM_TOKEN_MINT=
NEXT_PUBLIC_STAKING_PROGRAM_ID=
NEXT_PUBLIC_BRIDGE_ADDRESS=          # adresa Promethium Chain unde se trimite coin-ul
NEXT_PUBLIC_FEE_ADDRESS=             # adresa de fee pe Solana

# Explorer extern
NEXT_PUBLIC_EXPLORER_URL=            # URL block explorer open-source

# ---- Faucet (/faucet) ----
# With NO Twitter vars set, the faucet runs in DEMO MODE (a sample eligible X
# account is injected on "Connect") so the whole flow is testable without keys.
# Create an app at https://developer.x.com/ -> Web App, scopes tweet.read + users.read.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=               # only for confidential clients
TWITTER_REDIRECT_URI=               # must match X portal, e.g. https://promethium.work/api/faucet/auth/x/callback
# Session signing reuses SESSION_SECRET above.
NEXT_PUBLIC_FAUCET_NODE_ADDRESS=     # address miners send 0.001 PROM to (node bonus)
NEXT_PUBLIC_FAUCET_GUIDE_URL=/docs/get-started   # how to create a PROM address
FAUCET_ADMIN_TOKEN=                  # GET /api/faucet/admin/list with header x-admin-token: <token>
